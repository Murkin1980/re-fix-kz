---
const phoneDisplay = '+7 705 916 43 37';
const phoneE164 = '+77059164337';
const waNumber = '77059164337';
const canonical = 'https://re-fix.kz/';

const services = [
  ['Ремонт кухонь', 'Фасады, петли, ящики, направляющие, столешницы и встроенная техника.'],
  ['Ремонт шкафов', 'Шкафы-купе, распашные шкафы, двери, ролики, направляющие и крепления.'],
  ['Замена фурнитуры', 'Петли, ручки, доводчики, подъёмники, амортизаторы и направляющие.'],
  ['Столешницы и мойки', 'Замена столешниц, врезка моек, варочных панелей и герметизация.'],
  ['Фасады и ящики', 'Регулировка, ремонт, замена фасадов, восстановление геометрии ящиков.'],
  ['Мебель на заказ', 'Шкафы, кухни и гардеробные по индивидуальным размерам.']
];

const areas = ['Бостандыкский', 'Алмалинский', 'Ауэзовский', 'Медеуский', 'Жетысуский', 'Турксибский', 'Наурызбайский', 'Алатауский'];

const faq = [
  ['Выезд бесплатный?', 'Замер при заказе изготовления мебели — бесплатно. При ремонтных работах выезд мастера — 5 000 ₸, при выполнении ремонта сумма засчитывается в стоимость работ.'],
  ['Можно оценить по фото?', 'Да. Отправьте в WhatsApp фото поломки, район города и краткое описание задачи — мастер даст предварительную оценку.'],
  ['Какие работы делаете чаще всего?', 'Регулировка дверей, замена петель, ремонт ящиков, замена направляющих, ремонт шкафов-купе, кухонь и столешниц.'],
  ['Работаете по области?', 'Да, работаем по Алматы и ближайшей Алматинской области в радиусе примерно 100 км.']
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': 'https://re-fix.kz/#business',
  name: 'RE-FIX.KZ',
  alternateName: 'Re-Fix',
  url: canonical,
  description: 'Ремонт корпусной мебели, кухонь, шкафов, фасадов, ящиков, петель, направляющих, столешниц и мебельной фурнитуры в Алматы и Алматинской области.',
  telephone: phoneE164,
  email: 'info@re-fix.kz',
  priceRange: '₸₸',
  address: { '@type': 'PostalAddress', addressLocality: 'Алматы', addressCountry: 'KZ' },
  areaServed: [{ '@type': 'City', name: 'Алматы' }, { '@type': 'AdministrativeArea', name: 'Алматинская область' }],
  openingHoursSpecification: [{ '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'], opens: '09:00', closes: '20:00' }],
  makesOffer: services.map(([name]) => ({ '@type': 'Offer', itemOffered: { '@type': 'Service', name } }))
};
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>RE-FIX.KZ — ремонт корпусной мебели в Алматы</title>
    <meta name="description" content="Ремонт корпусной мебели в Алматы: кухни, шкафы, фасады, ящики, петли, направляющие, столешницы и фурнитура. WhatsApp-оценка по фото." />
    <meta name="keywords" content="ремонт мебели Алматы, ремонт кухни Алматы, ремонт шкафа Алматы, ремонт шкафа-купе Алматы, замена фурнитуры Алматы" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="RE-FIX.KZ — ремонт корпусной мебели в Алматы" />
    <meta property="og:description" content="Ремонт кухонь, шкафов, фасадов, ящиков, петель, направляющих и столешниц в Алматы. Оценка по фото через WhatsApp." />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="ru_KZ" />
    <meta name="theme-color" content="#1c2a32" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/png" href="/assets/logo.png" />
    <link rel="preload" href="/assets/logo.png" as="image" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <div class="ambient" aria-hidden="true"></div>

    <header class="site-header glass-nav">
      <a class="brand" href="#top" aria-label="RE-FIX.KZ главная">
        <img src="/assets/logo.png" alt="RE-FIX.KZ" width="132" height="40" />
      </a>
      <nav class="nav-links" aria-label="Основная навигация">
        <a href="#services">Услуги</a>
        <a href="#process">Как работаем</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Контакты</a>
      </nav>
      <a class="nav-phone" href={`tel:${phoneE164}`}>{phoneDisplay}</a>
    </header>

    <main id="top">
      <section class="hero section-shell">
        <div class="hero-copy glass-card hero-card">
          <p class="eyebrow">Алматы · выезд мастера · оценка по фото</p>
          <h1>Ремонт корпусной мебели без лишней суеты</h1>
          <p class="lead">Кухни, шкафы, фасады, ящики, петли, направляющие, столешницы и мебельная фурнитура. Отправьте фото в WhatsApp — подскажем решение и ориентир по стоимости.</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href={`https://wa.me/${waNumber}?text=${encodeURIComponent('Здравствуйте! Нужен ремонт мебели. Хочу отправить фото и получить оценку.')}`}>Оценить по WhatsApp</a>
            <a class="btn btn-ghost" href={`tel:${phoneE164}`}>Позвонить мастеру</a>
          </div>
          <div class="trust-row" aria-label="Преимущества">
            <span>10+ лет опыта</span>
            <span>Алматы + область</span>
            <span>Гарантия на работы</span>
          </div>
        </div>
        <div class="hero-visual glass-card" aria-label="Карточка сервиса">
          <div class="visual-badge">RE-FIX</div>
          <div class="visual-line"></div>
          <div class="visual-list">
            <span>Петли и доводчики</span>
            <span>Шкафы-купе</span>
            <span>Кухонные ящики</span>
            <span>Столешницы</span>
          </div>
        </div>
      </section>

      <section class="section-block" id="services">
        <div class="section-heading">
          <p class="eyebrow">Что ремонтируем</p>
          <h2>Основные услуги</h2>
          <p>Сфокусированы на корпусной мебели: то, что чаще всего ломается в кухнях, шкафах и гардеробных.</p>
        </div>
        <div class="cards-grid">
          {services.map(([title, text]) => (
            <article class="glass-card service-card">
              <span class="card-mark"></span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block split" id="process">
        <div class="glass-card panel">
          <p class="eyebrow">Как быстрее получить цену</p>
          <h2>Отправьте фото поломки</h2>
          <p>Для предварительной оценки достаточно 3 вещей: фото проблемного места, район города и краткое описание задачи.</p>
          <ol class="steps">
            <li><strong>Фото</strong><span>петли, ящика, фасада, столешницы или шкафа</span></li>
            <li><strong>Описание</strong><span>что сломалось и что нужно сделать</span></li>
            <li><strong>Контакт</strong><span>номер телефона и удобное время</span></li>
          </ol>
        </div>
        <div class="glass-card panel area-panel">
          <p class="eyebrow">Зона обслуживания</p>
          <h2>Алматы и ближайшая область</h2>
          <div class="area-tags">
            {areas.map((area) => <span>{area}</span>)}
          </div>
          <p class="muted">Выезд по области — по договорённости. Для ремонта выезд мастера 5 000 ₸; при выполнении работ сумма засчитывается в стоимость.</p>
        </div>
      </section>

      <section class="section-block" id="faq">
        <div class="section-heading">
          <p class="eyebrow">Частые вопросы</p>
          <h2>Коротко о ремонте и выезде</h2>
        </div>
        <div class="faq-grid">
          {faq.map(([question, answer]) => (
            <details class="glass-card faq-item">
              <summary>{question}</summary>
              <p>{answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="section-block contact-section" id="contact">
        <div class="glass-card contact-card">
          <div>
            <p class="eyebrow">Контакты</p>
            <h2>Связаться с мастером</h2>
            <p>Лучший способ — WhatsApp с фото. Так мастер быстрее поймёт объём работ и даст предварительный ориентир.</p>
          </div>
          <div class="contact-actions">
            <a class="btn btn-primary" href={`https://wa.me/${waNumber}?text=${encodeURIComponent('Здравствуйте! Интересует ремонт корпусной мебели. Прикрепляю фото.')}`}>Написать в WhatsApp</a>
            <a class="btn btn-ghost" href={`tel:${phoneE164}`}>{phoneDisplay}</a>
            <a class="text-link" href="mailto:info@re-fix.kz">info@re-fix.kz</a>
          </div>
        </div>
      </section>
    </main>

    <a class="float-wa" href={`https://wa.me/${waNumber}?text=${encodeURIComponent('Здравствуйте! Нужен ремонт мебели.')}`} aria-label="Написать в WhatsApp">WA</a>

    <footer class="footer">
      <p>© 2026 RE-FIX.KZ · ремонт корпусной мебели в Алматы</p>
      <a href="/llms.txt">llms.txt</a>
      <a href="/ai-site-profile.json">AI profile</a>
    </footer>
  </body>
</html>
